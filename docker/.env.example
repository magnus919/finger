# Finger Server Configuration
#
# Copy to .env and fill in your values.

# The user this container serves (required)
FINGER_USER=yourusername

# Email address for auth magic links (required for email auth)
FINGER_USER_EMAIL=you@example.com

# From address for auth emails (required for email auth)
FINGER_EMAIL_FROM=finger@example.com

# SMTP configuration (required for sending auth emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
